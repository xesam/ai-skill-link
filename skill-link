#!/usr/bin/env bash
set -euo pipefail

# Exit codes
EXIT_USAGE=1
EXIT_SKILL_NOT_FOUND=2
EXIT_TARGET_CONFLICT=3
EXIT_LINK_FAILED=4

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_REPO="$SCRIPT_DIR"
CONF_DEFAULT="$SCRIPT_DIR/skill-link.conf"
CONF_LOCAL="$SCRIPT_DIR/skill-link.local.conf"

show_help() {
  cat <<'USAGE'
Usage:
  skill-link <skill_name...> --cli <name> [options]
  skill-link --all --cli <name> [options]

Link selected skills from this repository into a known AI CLI skills directory.

Required:
  -c, --cli <name>        Target AI CLI name (use "all" to target every supported CLI)

Selection:
  <skill_name...>         One or more skill names (directory names)
  -a, --all               Link all available skills (mutually exclusive with skill names)

Options:
  -f, --force             Replace existing destination entry
  -n, --dry-run           Show planned actions without modifying files
  -r, --repo <dir>        Skills repository root (default: script directory)
  -u, --unlink            Remove symlinks instead of creating them
  -l, --list              List available skills and exit
      --list-clis         List supported CLI names and target paths
      --relative          Create relative symlinks instead of absolute symlinks
  -v, --verbose           Print extra logs
  -h, --help              Show this help

CLI configuration:
  Defined in skill-link.conf (default) and skill-link.local.conf (user overrides).
  Use --list-clis to see all configured CLIs.
  Use --cli all to target every configured CLI.
USAGE
}

fail() {
  printf '[ERR] %s\n' "$1" >&2
  exit "$2"
}

# Parse [clis] section from a config file, output "name=expanded_path" lines.
_parse_clis() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  local in_clis=0 key val
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    if [[ "$line" =~ ^\[([^\]]+)\] ]]; then
      [[ "${BASH_REMATCH[1]}" == "clis" ]] && in_clis=1 || in_clis=0
      continue
    fi
    if [[ "$in_clis" == 1 && "$line" == *=* ]]; then
      key="$(printf '%s' "${line%%=*}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      val="$(printf '%s' "${line#*=}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      [[ -z "$key" ]] && continue
      val="${val/#\~/$HOME}"
      printf '%s=%s\n' "$key" "$val"
    fi
  done < "$file"
}

# Parse [repo] section from a config file, output "name=expanded_path" lines.
_parse_repos() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  local in_repo=0 key val
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    if [[ "$line" =~ ^\[([^\]]+)\] ]]; then
      [[ "${BASH_REMATCH[1]}" == "repo" ]] && in_repo=1 || in_repo=0
      continue
    fi
    if [[ "$in_repo" == 1 && "$line" == *=* ]]; then
      key="$(printf '%s' "${line%%=*}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      val="$(printf '%s' "${line#*=}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      [[ -z "$key" ]] && continue
      val="${val/#\~/$HOME}"
      printf '%s=%s\n' "$key" "$val"
    fi
  done < "$file"
}

# Merge default and local repo configs; local entries override default.
_merged_repos() {
  {
    _parse_repos "$CONF_DEFAULT"
    _parse_repos "$CONF_LOCAL"
  } | awk '{
    idx = index($0, "=")
    if (idx > 0) { key = substr($0, 1, idx-1); entries[key] = $0 }
  } END { for (k in entries) print entries[k] }'
}

# Resolve repo name or path to actual path.
# If input matches a named repo in config, return its path; otherwise return input as-is.
resolve_repo() {
  local input="$1" name val
  while IFS= read -r line; do
    name="${line%%=*}"
    val="${line#*=}"
    [[ "$name" == "$input" ]] && printf '%s\n' "$val" && return 0
  done < <(_merged_repos)
  printf '%s\n' "$input"
}

# Get default repo path: config [repo] default, or fallback to script directory.
default_repo() {
  local name val
  while IFS= read -r line; do
    name="${line%%=*}"
    val="${line#*=}"
    [[ "$name" == "default" ]] && printf '%s\n' "$val" && return 0
  done < <(_merged_repos)
  printf '%s\n' "$DEFAULT_REPO"
}

# Merge default and local configs; local entries override default (last wins per key).
_merged_clis() {
  {
    _parse_clis "$CONF_DEFAULT"
    _parse_clis "$CONF_LOCAL"
  } | awk '{
    idx = index($0, "=")
    if (idx > 0) { key = substr($0, 1, idx-1); entries[key] = $0 }
  } END { for (k in entries) print entries[k] }' | sort
}

# Return the skills directory for a CLI name (from merged config).
cli_target_dir() {
  local cli="$1" name val
  while IFS= read -r line; do
    name="${line%%=*}"
    val="${line#*=}"
    [[ "$name" == "$cli" ]] && printf '%s\n' "$val" && return 0
  done < <(_merged_clis)
  return 1
}

list_supported_clis() {
  local name val
  while IFS= read -r line; do
    name="${line%%=*}"
    val="${line#*=}"
    printf '%-12s -> %s\n' "$name" "$val"
  done < <(_merged_clis)
}

# All CLI names from merged config, used when --cli all is specified.
all_cli_names() {
  _merged_clis | while IFS= read -r line; do printf '%s\n' "${line%%=*}"; done
}

list_skills() {
  local repo="$1"
  # Treat each top-level directory containing SKILL.md as one skill.
  find "$repo" -mindepth 2 -maxdepth 2 -type f -name 'SKILL.md' -print \
    | sed -E "s#^$repo/##" \
    | cut -d/ -f1 \
    | sort -u
}

relpath() {
  local from="$1"
  local to="$2"
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$from" "$to" <<'PY'
import os
import sys
print(os.path.relpath(sys.argv[2], sys.argv[1]))
PY
    return 0
  fi
  return 1
}

CLI_NAME=""
REPO_ARG=""
USE_ALL=0
FORCE=0
DRY_RUN=0
USE_RELATIVE=0
DO_UNLINK=0
VERBOSE=0
DO_LIST=0
DO_LIST_CLIS=0

SKILLS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--cli)
      [[ $# -ge 2 ]] || fail "Missing value for $1" "$EXIT_USAGE"
      CLI_NAME="$2"
      shift 2
      ;;
    -r|--repo)
      [[ $# -ge 2 ]] || fail "Missing value for $1" "$EXIT_USAGE"
      REPO_ARG="$2"
      shift 2
      ;;
    -a|--all)
      USE_ALL=1
      shift
      ;;
    -f|--force)
      FORCE=1
      shift
      ;;
    -n|--dry-run)
      DRY_RUN=1
      shift
      ;;
    --relative)
      USE_RELATIVE=1
      shift
      ;;
    -v|--verbose)
      VERBOSE=1
      shift
      ;;
    -u|--unlink)
      DO_UNLINK=1
      shift
      ;;
    -l|--list)
      DO_LIST=1
      shift
      ;;
    --list-clis)
      DO_LIST_CLIS=1
      shift
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        SKILLS+=("$1")
        shift
      done
      ;;
    -*)
      fail "Unknown option: $1" "$EXIT_USAGE"
      ;;
    *)
      SKILLS+=("$1")
      shift
      ;;
  esac
done

# Determine REPO_ROOT: --repo arg > config default > script directory
if [[ -n "$REPO_ARG" ]]; then
  REPO_ROOT="$(resolve_repo "$REPO_ARG")"
else
  REPO_ROOT="$(default_repo)"
fi

REPO_ROOT="$(cd "$REPO_ROOT" && pwd)"

if [[ "$DO_LIST" == "1" ]]; then
  list_skills "$REPO_ROOT"
  exit 0
fi

if [[ "$DO_LIST_CLIS" == "1" ]]; then
  list_supported_clis
  exit 0
fi

if [[ "$USE_ALL" == "1" && "${#SKILLS[@]}" -gt 0 ]]; then
  fail "--all cannot be used with explicit skill names" "$EXIT_USAGE"
fi

if [[ -z "$CLI_NAME" ]]; then
  fail "--cli is required" "$EXIT_USAGE"
fi

# Expand "all" into canonical CLI names; validate single name otherwise.
CLI_NAMES=()
if [[ "$CLI_NAME" == "all" ]]; then
  while IFS= read -r n; do CLI_NAMES+=("$n"); done < <(all_cli_names)
else
  cli_target_dir "$CLI_NAME" > /dev/null || fail "Unsupported CLI: $CLI_NAME (use --list-clis)" "$EXIT_USAGE"
  CLI_NAMES=("$CLI_NAME")
fi

if [[ "$USE_ALL" == "1" ]]; then
  while IFS= read -r skill_name; do
    SKILLS+=("$skill_name")
  done < <(list_skills "$REPO_ROOT")
fi

if [[ "${#SKILLS[@]}" -eq 0 ]]; then
  fail "No skills specified. Provide skill names or use --all" "$EXIT_USAGE"
fi

total_failed=0
total_conflicts=0
total_missing=0

for cli_name in "${CLI_NAMES[@]}"; do
  TARGET_DIR="$(cli_target_dir "$cli_name")"

  if [[ "${#CLI_NAMES[@]}" -gt 1 ]]; then
    printf '\n==> %s (%s)\n' "$cli_name" "$TARGET_DIR"
  fi

  if [[ "$DRY_RUN" == "1" ]]; then
    printf '[DRY-RUN] ensure target dir: %s\n' "$TARGET_DIR"
  else
    mkdir -p "$TARGET_DIR"
  fi

  success=0
  skipped=0
  failed=0
  conflicts=0
  missing=0

  for skill in "${SKILLS[@]}"; do
    src="$REPO_ROOT/$skill"
    dst="$TARGET_DIR/$skill"

    if [[ "$DO_UNLINK" == "1" ]]; then
      if [[ ! -e "$dst" && ! -L "$dst" ]]; then
        printf '[SKIP] not linked: %s\n' "$dst"
        skipped=$((skipped + 1))
        continue
      fi

      if [[ -L "$dst" ]]; then
        current="$(readlink "$dst")"
        src_abs="$(cd "$src" 2>/dev/null && pwd)" || src_abs="$src"
        if [[ "$current" = /* ]]; then
          current_resolved="$current"
        else
          current_resolved="$(cd "$(dirname "$dst")/$current" 2>/dev/null && pwd)" || current_resolved=""
        fi

        if [[ "$current_resolved" != "$src_abs" && "$current" != "$src" ]]; then
          if [[ "$FORCE" != "1" ]]; then
            printf '[ERR] symlink points elsewhere (%s), use --force to remove: %s\n' "$current" "$dst" >&2
            failed=$((failed + 1))
            conflicts=$((conflicts + 1))
            continue
          fi
        fi

        if [[ "$DRY_RUN" == "1" ]]; then
          printf '[DRY-RUN] rm %s\n' "$dst"
          success=$((success + 1))
        else
          rm -f "$dst"
          printf '[OK] unlinked: %s\n' "$dst"
          success=$((success + 1))
        fi
        continue
      fi

      if [[ "$FORCE" != "1" ]]; then
        printf '[ERR] not a symlink: %s, use --force to remove\n' "$dst" >&2
        failed=$((failed + 1))
        conflicts=$((conflicts + 1))
        continue
      fi
      if [[ "$DRY_RUN" == "1" ]]; then
        printf '[DRY-RUN] rm -rf %s\n' "$dst"
        success=$((success + 1))
      else
        rm -rf "$dst"
        printf '[OK] removed: %s\n' "$dst"
        success=$((success + 1))
      fi
      continue
    fi

    if [[ ! -d "$src" || ! -f "$src/SKILL.md" ]]; then
      printf '[ERR] skill not found or invalid: %s\n' "$skill" >&2
      failed=$((failed + 1))
      missing=$((missing + 1))
      continue
    fi

    link_src="$src"
    # Relative links improve portability when moving parent directories together.
    if [[ "$USE_RELATIVE" == "1" ]]; then
      if rel="$(relpath "$TARGET_DIR" "$src")"; then
        link_src="$rel"
      else
        printf '[ERR] --relative requested but python3 is not available\n' >&2
        failed=$((failed + 1))
        continue
      fi
    fi

    if [[ -L "$dst" ]]; then
      current="$(readlink "$dst")"
      if [[ "$current" == "$link_src" || "$current" == "$src" ]]; then
        printf '[SKIP] already linked: %s -> %s\n' "$dst" "$current"
        skipped=$((skipped + 1))
        continue
      fi
      if [[ "$FORCE" == "1" ]]; then
        if [[ "$DRY_RUN" == "1" ]]; then
          printf '[DRY-RUN] remove existing symlink: %s\n' "$dst"
        else
          rm -f "$dst"
        fi
      else
        printf '[ERR] destination exists with different symlink: %s\n' "$dst" >&2
        failed=$((failed + 1))
        conflicts=$((conflicts + 1))
        continue
      fi
    elif [[ -e "$dst" ]]; then
      if [[ "$FORCE" == "1" ]]; then
        if [[ "$DRY_RUN" == "1" ]]; then
          printf '[DRY-RUN] remove existing path: %s\n' "$dst"
        else
          rm -rf "$dst"
        fi
      else
        printf '[ERR] destination exists and is not a symlink: %s\n' "$dst" >&2
        failed=$((failed + 1))
        conflicts=$((conflicts + 1))
        continue
      fi
    fi

    if [[ "$DRY_RUN" == "1" ]]; then
      printf '[DRY-RUN] ln -s %s %s\n' "$link_src" "$dst"
      success=$((success + 1))
    else
      if ln -s "$link_src" "$dst"; then
        printf '[OK] linked: %s -> %s\n' "$dst" "$link_src"
        success=$((success + 1))
      else
        printf '[ERR] failed to link: %s -> %s\n' "$dst" "$link_src" >&2
        failed=$((failed + 1))
      fi
    fi

  done

  printf 'Summary: success=%d skipped=%d failed=%d\n' "$success" "$skipped" "$failed"

  total_failed=$((total_failed + failed))
  total_conflicts=$((total_conflicts + conflicts))
  total_missing=$((total_missing + missing))

done

if [[ "$total_failed" -gt 0 ]]; then
  if [[ "$total_missing" -gt 0 && "$total_conflicts" -eq 0 ]]; then
    exit "$EXIT_SKILL_NOT_FOUND"
  fi
  if [[ "$total_conflicts" -gt 0 ]]; then
    exit "$EXIT_TARGET_CONFLICT"
  fi
  exit "$EXIT_LINK_FAILED"
fi

exit 0
